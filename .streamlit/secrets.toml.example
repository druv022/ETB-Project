# Copy to `.streamlit/secrets.toml` (do not commit real values).
# Streamlit also reads the same keys from the process environment (e.g. Docker `.env`).

ETB_ADMIN_USERNAME = "change-me-admin"
ETB_ADMIN_PASSWORD = "change-me-strong-password"

# Same value must be set on orchestrator and retriever when using admin Logs/Documents APIs.
ETB_ADMIN_API_TOKEN = "generate-with-python-secrets-token-urlsafe-32"

# When set on the orchestrator, chat requires this Bearer token (set the same here for the UI).
# ETB_ORCHESTRATOR_API_KEY = ""

# When the retriever enforces API keys, set the same value here for uploads and asset images.
# RETRIEVER_API_KEY = ""
